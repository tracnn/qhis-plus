{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/qhis-plus/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/qhis-plus/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/qhis-plus",
  "projects": {
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "kiem-tra-the-bhyt": {
      "type": "application",
      "root": "apps/kiem-tra-the-bhyt",
      "entryFile": "main",
      "sourceRoot": "apps/kiem-tra-the-bhyt/src",
      "compilerOptions": {
        "tsConfigPath": "apps/kiem-tra-the-bhyt/tsconfig.app.json"
      }
    },
    "kiennt": {
      "type": "application",
      "root": "apps/kiennt",
      "entryFile": "main",
      "sourceRoot": "apps/kiennt/src",
      "compilerOptions": {
        "tsConfigPath": "apps/kiennt/tsconfig.app.json"
      }
    },
    "qhis-plus": {
      "type": "application",
      "root": "apps/qhis-plus",
      "entryFile": "main",
      "sourceRoot": "apps/qhis-plus/src",
      "compilerOptions": {
        "tsConfigPath": "apps/qhis-plus/tsconfig.app.json"
      }
    },
    "thaovh": {
      "type": "application",
      "root": "apps/thaovh",
      "entryFile": "main",
      "sourceRoot": "apps/thaovh/src",
      "compilerOptions": {
        "tsConfigPath": "apps/thaovh/tsconfig.app.json"
      }
    },
    "the-bhyt": {
      "type": "application",
      "root": "apps/the-bhyt",
      "entryFile": "main",
      "sourceRoot": "apps/the-bhyt/src",
      "compilerOptions": {
        "tsConfigPath": "apps/the-bhyt/tsconfig.app.json"
      }
    },
    "tracnn": {
      "type": "application",
      "root": "apps/tracnn",
      "entryFile": "main",
      "sourceRoot": "apps/tracnn/src",
      "compilerOptions": {
        "tsConfigPath": "apps/tracnn/tsconfig.app.json"
      }
    },
    "user-service": {
      "type": "application",
      "root": "apps/user-service",
      "entryFile": "main",
      "sourceRoot": "apps/user-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-service/tsconfig.app.json"
      }
    }
  }
}